# Shorten pnpm's virtual-store (.pnpm) directory names. electron-builder's
# bundled NSIS (makensis) is not long-path aware on Windows, and pnpm's default
# 120-char peer-dependency hash dirs push the app-builder-lib NSIS template
# include paths past the 260-char MAX_PATH limit, breaking installer creation.
virtual-store-dir-max-length=60
