// DAZ Studio version 4.22.0.16 filetype DAZ Script

//include("./util.dsa");

var DTH_VERBOSE = false;
var EPSILON = .0001;

function verbose(){
	if( DTH_VERBOSE ){
		print.apply(this, arguments);
	}
}

/**********************************************************************
 * ROM run log — collects every problem of a run (a morph that couldn't be
 * applied, a preset that failed to load, any unexpected error) so the run can
 * finish drift-free and the studio can show exactly what failed afterwards.
 * Written as JSON by writeRunLog (path baked into the generated script). */
var DTH_RUN_LOG = { errors: [], failedMorphs: [] };

function resetRunLog(){
	DTH_RUN_LOG = { errors: [], failedMorphs: [] };
}

/** A general problem (preset failed, node missing, unexpected error, …). */
function logRunError(sMessage){
	DTH_RUN_LOG.errors.push(String(sMessage));
	print("ERROR:", sMessage);
}

/** One morph/property that couldn't be applied — the frame slot stays, only
 *  this morph is missing, and the studio lists it after the run. */
function logRunFailedMorph(iFrame, sNode, sProp, sReason){
	DTH_RUN_LOG.failedMorphs.push({
		frame: iFrame, node: String(sNode), prop: String(sProp), reason: String(sReason)
	});
	print("FAILED MORPH: frame", iFrame, "-", sNode, "/", sProp, "-", sReason);
}

function runLogProblemCount(){
	return DTH_RUN_LOG.errors.length + DTH_RUN_LOG.failedMorphs.length;
}

/** Write the run log JSON to sPath. oSummary carries the run metadata
 *  (character, versions, frame counts, ok) baked in by the caller. */
function writeRunLog(sPath, oSummary){
	if(!sPath) return false;
	var oLog = oSummary || {};
	oLog.logVersion = 1;
	oLog.finishedAt = new Date().toString();
	oLog.finishedAtMs = new Date().getTime();
	oLog.errors = DTH_RUN_LOG.errors;
	oLog.failedMorphs = DTH_RUN_LOG.failedMorphs;
	try {
		var oFile = new DzFile(sPath);
		// One ORed mode arg — DzFile.open(mode) takes a single flags int; a second
		// argument was silently ignored on DS4 but warns on DS6 ("Too many arguments").
		if(oFile.open(oFile.WriteOnly | oFile.Truncate)){
			oFile.write(JSON.stringify(oLog, null, 2));
			oFile.close();
			print("Run log written to", sPath);
			return true;
		}
		print("Could not open run log for writing:", sPath);
	} catch(e) {
		print("Failed writing run log:", e);
	}
	return false;
}
/**********************************************************************
 * DAZ Studio 6 detection (JoxiMoon's field-tested 3-tier pattern, trimmed to
 * the version APIs — no material at hand here for feature detection; with no
 * version API at all we assume DS4-era, whose Linear keys are correct). */
function dthDetectDaz6(){
	if (typeof App != "undefined" && typeof App.versionString == "string") {
		return App.versionString.indexOf("6.") == 0;
	}
	if (typeof App != "undefined" && typeof App.getVersionString == "function") {
		return App.getVersionString().indexOf("6.") == 0;
	}
	return false;
}
var DTH_IS_DAZ6 = dthDetectDaz6();

/**********************************************************************
 * Stamp the ROM's morph keys with the interpolation the running Daz needs:
 * LINEAR on DS4 (the validated original behavior), CONSTANT on DS6 — DS6's
 * animation engine drifts Linear-interpolated ROM keys across the timeline
 * (mrpdean, June 2026: "G9 DQS JCM FAC" cheek poses creeping); converting
 * every key to Constant after applying is his validated workaround. */
function setLinearInterp(oNodes, startFrame, endFrame){

	// Set the session default to match, so keys created later start out right.
	Scene.setDefaultKeyInterpolationType(DTH_IS_DAZ6 ? DzProperty.Constant : DzProperty.Linear);

 	startFrame = typeof startFrame !== 'undefined' ? startFrame : 0;
 	endFrame = typeof endFrame !== 'undefined' ? endFrame : 0;
	var props = [];

	// Properties to skip (transforms should never be touched)
	var skipProps = ["Scale", "XScale", "YScale", "ZScale",
					 "XRotate", "YRotate", "ZRotate",
					 "XTranslate", "YTranslate", "ZTranslate",
					 "General Scale", "X Scale", "Y Scale", "Z Scale"];

	for(var x = 0; x < oNodes.length; x++)
	{
		var oNode = oNodes[x];
		var oObj = oNode.getObject();
		// Only process morph modifiers, NOT node properties (which include Scale/Transform)
		if(oObj){
			for(var i=0; i<oObj.getNumModifiers(); i++)
			{
				var oMod = oObj.getModifier(i);
				if(oMod && oMod.inherits("DzMorph"))
				{
					var oProp = oMod.getValueControl();
					if(oProp && oProp.getNumKeys() > 1)
					{
						props.push(oProp);
					}
				}
			}
		}
		// Skip node properties entirely - they include Scale/Transform which should never be modified
	}
	print("Morph props to set", DTH_IS_DAZ6 ? "CONSTANT" : "LINEAR", "interp:", props.length)
	var iInterp = DTH_IS_DAZ6 ? DzFloatProperty.CONSTANT_INTERP : DzFloatProperty.LINEAR_INTERP;
	for( var i = 0; i < props.length; i++){
		oProp = props[i];
		for( var j = 0; j < oProp.getNumKeys(); j++) {
			// Only set interpolation type - do NOT call setValue as it can modify values
			oProp.setKeyInterpolationType(j, iInterp);
		}
	}
}

/**********************************************************************
 * Loads preset `sFilename` with `oTarget` node selected, at frame `startframe` 
 * startFrame = 0 		*/
function loadPreset(sFilename, oTarget, startFrame)
{
 	startFrame = typeof startFrame !== 'undefined' ? startFrame : 0;
 	var oContentMgr = App.getContentMgr();
	print("Loading", sFilename, "to", oTarget.getLabel(), "at frame", startFrame);
	var newTime = Scene.getTimeStep() * startFrame;
	Scene.selectAllNodes(false);
	oTarget.select(true);
	Scene.setPrimarySelection(oTarget);
	Scene.setTime(newTime);
	return oContentMgr.openFile(sFilename);
}

/**********************************************************************
 *Sets total frames */
function setTotalFrames(iTotalFrames){
	var oTimeRange = new DzTimeRange(0, iTotalFrames * Scene.getTimeStep());
	print("Setting new time range:", oTimeRange.start, "to", oTimeRange.end);
	Scene.setAnimRange(oTimeRange);
	// Also extend the play range — otherwise the timeline scrubber stays bounded
	// to the previous (shorter) play range and you can't reach the later frames
	// (e.g. the FBM section after the GP block).
	Scene.setPlayRange(oTimeRange);
}

/**********************************************************************
 *Adds new frames to end of the anim play range. No arguments adds 1 frame.*/
function addFramesToAnim(iNewFrames){
 iNewFrames = typeof iNewFrames !== 'undefined' ? iNewFrames : 1;
	var oTimeRange = new DzTimeRange(0, Scene.getAnimRange().end + Scene.getTimeStep(0) * iNewFrames);
	Scene.setAnimRange(oTimeRange);
}

/**********************************************************************
 *Memorizes figure for `oNode` at `iSourceFrame`, Restores Figure for each frame in `aTargetFrames`.*/
function setFencePoses(oNode, iSourceFrame, aTargetFrames){
	var timeStep = Scene.getTimeStep();
	Scene.selectAllNodes(false);
	oNode.select();
	Scene.setPrimarySelection(oNode);
	Scene.setTime(iSourceFrame * timeStep);
	print("Memorizing figure for:", oNode.getLabel(), "at frame", iSourceFrame);
	triggerAction("DzMemorizeFigureAction");
	// Indexed loop, NOT for-in: DAZ's engine exposes enumerable Array.prototype
	// extensions (map/forEach/…), so for-in over an array also yields those —
	// restoring the figure at frame `function f(){…}` (NaN time) and "".
	for( var i = 0; i < aTargetFrames.length; i++){
		var frame = aTargetFrames[i];
		Scene.setTime(frame * timeStep);
		print("Restoring figure for:", oNode.getLabel(), "at frame", frame);
		triggerAction("DzRestoreFigureAction");	
	}
}

// function getKeysAtFrame(oNode, )

/**********************************************************************
 *Sets property `sPropName` on `oNode` to `fValue` at time `iFrame`.
 * iFrame = 0  		*/
function setPropertyByName(oNode, sPropName, fValue, iFrame){
 	iFrame = typeof iFrame !== 'undefined' ? iFrame : 0;
 	print("Setting property", sPropName, "to", fValue, "at frame", iFrame, "...");
	var oProp = oNode.findProperty(sPropName);
	if (!oProp){
		logRunFailedMorph(iFrame, oNode.getLabel(), sPropName, "property not found");
		return false;
	}
	var tFrame = iFrame * Scene.getTimeStep();
	// setValue returns false when the value is ALREADY fValue (nothing to change),
	// so don't gate success on its return — verify by reading the value back. This
	// stops a no-op (e.g. FACS Detail Strength already at 1) logging a false "Failed".
	oProp.setValue(tFrame, fValue, DzProperty.Linear);
	if (approx_eq(oProp.getValue(tFrame), fValue)){
		print("Set property", oProp.getLabel(), "to", fValue, "at frame", iFrame);
		return true;
	}
	logRunFailedMorph(iFrame, oNode.getLabel(), sPropName, "value did not apply (limits?)");
	return false;
}


/** deprecated - use loadPreset ***********************/
function loadDufToNode(oNodeRoot, sDufPath, sChildLabel){
	var oChildNode;
	if(sChildLabel) 
		oChildNode = oNodeRoot.findNodeChildByLabel(sChildLabel);
	if(!oChildNode){
		Scene.setPrimarySelection(oNodeRoot);
		print("Loading DUF: ", sDufPath, "to add", sChildLabel, "to node", oNodeRoot.getLabel(), "...");
		if( oContentMgr.openFile(sDufPath) ) {
			print("Successfully loaded");
			return true;
		} else {
			print("Failed to load DUF: ", sDufPath, "to add", sChildLabel, "to node", oNodeRoot.getLabel(), "...");
			return false;
		}
	} else {
		print(sChildLabel, "already exists on node:", oNodeRoot.getLabel());
		return true;
	}
}

function getMorphPropFromNode(oNode, sMorphName){
	var oObj = oNode.getObject();
	if(oObj)
	{
		var oMorph = oObj.findModifier(sMorphName);
		if(oMorph){
			// getValueChannel() takes no args — passing 0 logs "Too many
			// arguments, ignoring 1" on every morph (this is the hot path).
			var oProp = oMorph.getValueChannel();
			return oProp;
		}
	}
}

function addFrameData(frameDatas, keyData){
	var idx = keyData.frameIdx;
	if(idx == undefined || idx == null)
		return false;
	if (frameDatas[idx] !== undefined)
		frameDatas[idx].keyDatas.push(keyData);
	else
		frameDatas[idx] = {frameName: "", sectionName: "", keyDatas: [keyData]};
	return true;
}

// Frame data JSON format (inline `config.extraFrames` of the character script):
// {
//   "meta": { "version": "1.0", "description": "..." },
//   "frames": [
//     {
//       "frame": 100,  // Relative frame offset (added to iOffset)
//       "section": "GP9",
//       "name": "Anus_Open",
//       "morphs": [
//         { "node": "GoldenPalace_G9", "prop": "GP9_Anus_Open", "value": 1.0 },
//         { "node": "GoldenPalace_G9", "prop": "GP9_Anus_Depth", "value": 0.5, "base": 0.2 }
//       ]
//     }
//   ]
// }
/**
 * Process an already-parsed frame-data object (the inline `config.extraFrames`
 * of the character script — same shape as the historical *_FBMs.json files)
 * into `frameDatas`. Gen-block leakage needs no handling here: runtime v27
 * closes every block's dangling keys at its boundary (closeDanglingMorphKeys).
 */
function processFrameDataJSON(jsonData, frameDatas, iOffset){
	frameDatas = frameDatas || [];
	iOffset = iOffset || 0;

	if (!jsonData || !jsonData.frames || !Array.isArray(jsonData.frames)) {
		print("ERROR: frame data missing 'frames' array");
		return frameDatas;
	}

	var frameCount = 0;
	for (var i = 0; i < jsonData.frames.length; i++) {
		var frameEntry = jsonData.frames[i];
		var frameNum = parseInt(frameEntry.frame) + iOffset;
		// A bad frame number must not silently shorten the timeline (drift!) —
		// log it and skip just this entry; every valid frame keeps its slot.
		if (isNaN(frameNum) || frameNum < 0) {
			logRunError("Frame entry " + i + " ('" + (frameEntry.name || "") +
				"') has an invalid frame number: " + frameEntry.frame);
			continue;
		}

		if (!frameDatas[frameNum]) {
			frameDatas[frameNum] = {
				keyDatas: [],
				sectionName: frameEntry.section || "",
				frameName: frameEntry.name || ""
			};
		}

		if (frameEntry.morphs && Array.isArray(frameEntry.morphs)) {
			for (var j = 0; j < frameEntry.morphs.length; j++) {
				var morph = frameEntry.morphs[j];
				var keyData = {
					frameIdx: frameNum,
					nodeName: morph.node,
					propName: morph.prop,
					propValue: parseFloat(morph.value),
					baseValue: (morph.base !== undefined) ? parseFloat(morph.base) : 0,
					autoBase: (morph.autoBase === true)
				};
				addFrameData(frameDatas, keyData);
				verbose("add JSON frame data. frame:", frameNum, "prop:", morph.prop, "base:", keyData.baseValue, "autoBase:", keyData.autoBase);
			}
		}
		frameCount++;
	}

	// Optional `groups` array: frame ranges whose generation method needs a
	// differently shaped timeline (additive: the first pose sustains across
	// the group; cumulative: every pose sustains until the group end).
	if (jsonData.groups && Array.isArray(jsonData.groups)) {
		annotateGroupMethods(frameDatas, jsonData.groups, iOffset);
	}

	print("added", frameCount, "frames from frame data");
	return frameDatas;
}


/** Marks the keyDatas of additive/cumulative group ranges so applyKeyData
 *  can create sustained keys instead of the per-frame sawtooth.
 *  advancedAdditive shapes the timeline like additive (the distinction is
 *  Houdini-side). Props repeating within a cumulative group are ramps
 *  (e.g. AnusOpen 22/35/80) — they skip the base re-anchor before their frame. */
function annotateGroupMethods(frameDatas, groups, iOffset){
	for (var g = 0; g < groups.length; g++) {
		var group = groups[g];
		var method = group.method === "advancedAdditive" ? "additive" : group.method;
		if (method !== "additive" && method !== "cumulative") continue;
		var startFrame = parseInt(group.startFrame) + iOffset;
		var endFrame = parseInt(group.endFrame) + iOffset;
		var seenProps = {};
		for (var f = startFrame; f <= endFrame; f++) {
			var frameData = frameDatas[f];
			if (!frameData || !frameData.keyDatas) continue;
			for (var k = 0; k < frameData.keyDatas.length; k++) {
				var keyData = frameData.keyDatas[k];
				var propKey = keyData.nodeName + "|" + keyData.propName;
				keyData.groupMethod = method;
				keyData.groupStart = startFrame;
				keyData.groupEnd = endFrame;
				keyData.isGroupBase = (f === startFrame);
				keyData.rampContinuation = (seenProps[propKey] === true);
				seenProps[propKey] = true;
			}
		}
		print("annotated", method, "group", (group.name || ""), "frames", startFrame, "-", endFrame);
	}
}

function printCSV(frameDatas, sOutFilename){
	lines = [];
	if(!frameDatas){
		print("ERROR: printCSV received null `frameDatas`");
		return false;
	}
	for (i = 0; i < frameDatas.length; i++){
		var line;
		var frameData = frameDatas[i];
		if(frameData && frameData.keyDatas !== undefined)
		{ 
			var keyDatas = frameData.keyDatas;
			line = [i.toString(), frameData.sectionName || "", frameData.frameName || ""];
			verbose("Frame", i, "length:", keyDatas.length);	
			for (j = 0; j < keyDatas.length; j++)
			{
				var keyData = keyDatas[j];
				line.push(keyData.nodeName, keyData.propName, keyData.propValue);
			}
			verbose("line length:", line.length);
		}
		else{
			line = [i.toString(), "", ""];
		}
		lines.push(line.join(","));
	}

	if(sOutFilename){
		oFile = new DzFile( sOutFilename );
		if ( oFile.open( oFile.WriteOnly, oFile.Truncate ) ) {

			print("Writing to", sOutFilename);
			for (var n = 0; n < lines.length; n++){
				print(lines[n]);
				oFile.write(lines[n] + "\n");
		    }
		    oFile.close();
		}	
	}
	else
	{
		for (var n = 0; n<lines.length;n++){
			print(lines[n]);
		}
	}
	
}

/** **************************************************************************/
function createMorphFrames( oNode, morphConfigs, iStartFrame){
	print("Entering createMorphFrames at frame ", iStartFrame, ", creating ", morphConfigs.length, "frames");
	if(!oNode){
		print("oNode null, returning");
		return false;
	}
	var timeStep = Scene.getTimeStep();
	var iNewFrames = (iStartFrame + morphConfigs.length) - (Scene.getAnimRange().end/timeStep);
	if(iNewFrames > 0)
		addFramesToAnim(iNewFrames);

	for(var i=1; i<morphConfigs.length; i++){
		print("executing morph", i, " in configs");
		var frameConfig = morphConfigs[i];
		// print("   " + frameConfig);
		for ( var j=0; j<frameConfig.length; j++){
			var config = frameConfig[j];
			var oProp = oNode.findProperty(config.name);
			if (!oProp)
				oProp = oNode.findPropertyByLabel(config.name);
			if(!oProp){
				oProp = getMorphPropFromNode(oNode, config.name)
			}
			if(!oProp){
				// continue (NOT break): one missing morph must not drop the rest
				// of this frame's morphs — the frame slot and count stay intact.
				logRunFailedMorph(iStartFrame + i, oNode.getLabel(), config.name, "morph/property not found");
				continue;
			}
			fValue = config.value || 1;
			var success = createMorphFrame(oProp, iStartFrame + i, fValue);

		}
	}
}


// Reset all morphs in frameDatas to 0 at a specific frame (typically frame 0)
// This preserves the base state and prevents interpolation issues
function resetFrameDatasAtFrame(oNodeRoot, frameDatas, resetFrame){
	resetFrame = resetFrame || 0;
	var timeStep = Scene.getTimeStep();
	var processedProps = {}; // Track which props we've already reset

	for(var i = 0; i < frameDatas.length; i++){
		var frameData = frameDatas[i];
		if(frameData && frameData.keyDatas){
			for(var j = 0; j < frameData.keyDatas.length; j++){
				var keyData = frameData.keyDatas[j];
				if(!keyData.propName || processedProps[keyData.propName]) continue;

				// Find the node
				var oNode;
				if(oNodeRoot.getName() == keyData.nodeName || oNodeRoot.getLabel() == keyData.nodeName)
					oNode = oNodeRoot;
				else
					oNode = oNodeRoot.findNodeChild(keyData.nodeName, true);
				if(!oNode)
					oNode = oNodeRoot.findNodeChildByLabel(keyData.nodeName, true);

				if(oNode){
					// Find the property (same logic as applyKeyData)
					var oProp = getMorphPropFromNode(oNode, keyData.propName);
					if(!oProp){
						var oObj = oNode.getObject();
						if(oObj){
							for(var m = 0; m < oObj.getNumModifiers(); m++){
								var mod = oObj.getModifier(m);
								if(mod.getLabel() === keyData.propName || mod.getName() === keyData.propName){
									if(mod.getValueChannel) oProp = mod.getValueChannel();
									if(!oProp && mod.getValueControl) oProp = mod.getValueControl();
									if(oProp) break;
								}
							}
						}
					}

					if(oProp){
						// Use baseValue for reset (respects pre-existing morph values)
						var resetValue = (keyData.baseValue !== undefined) ? keyData.baseValue : 0;
						oProp.setValue(resetFrame * timeStep, resetValue);
						processedProps[keyData.propName] = true;
						verbose("Reset", keyData.propName, "to", resetValue, "at frame", resetFrame);
					}
				}
			}
		}
	}
	print("Reset", Object.keys(processedProps).length, "morphs at frame", resetFrame);
}


/** Resolves autoBase flags in frameDatas by reading current property values from the scene.
 *  Must be called before applyFrameDatas so that baseValue reflects the scene state. */
function resolveAutoBaseValues(oNodeRoot, frameDatas){
	var resolved = 0;
	for(var i = 0; i < frameDatas.length; i++){
		var frameData = frameDatas[i];
		if(frameData && frameData.keyDatas){
			for(var j = 0; j < frameData.keyDatas.length; j++){
				var keyData = frameData.keyDatas[j];
				if(!keyData.autoBase) continue;

				// Find the node
				var oNode;
				if(oNodeRoot.getName() == keyData.nodeName || oNodeRoot.getLabel() == keyData.nodeName)
					oNode = oNodeRoot;
				else
					oNode = oNodeRoot.findNodeChild(keyData.nodeName, true);
				if(!oNode)
					oNode = oNodeRoot.findNodeChildByLabel(keyData.nodeName, true);

				if(oNode){
					var oProp = getMorphPropFromNode(oNode, keyData.propName);
					if(!oProp){
						var oObj = oNode.getObject();
						if(oObj){
							for(var m = 0; m < oObj.getNumModifiers(); m++){
								var mod = oObj.getModifier(m);
								if(mod.getLabel() === keyData.propName || mod.getName() === keyData.propName){
									if(mod.getValueChannel) oProp = mod.getValueChannel();
									if(!oProp && mod.getValueControl) oProp = mod.getValueControl();
									if(oProp) break;
								}
							}
						}
					}

					if(oProp){
						// Read the current value at time 0 (base state)
						var currentValue = oProp.getValue(0);
						keyData.baseValue = currentValue;
						print("autoBase resolved:", keyData.propName, "current value:", currentValue);
						resolved++;
					}
				}
				// Clear the flag so it's not re-processed
				keyData.autoBase = false;
			}
		}
	}
	if(resolved > 0) print("Resolved", resolved, "autoBase morph values from scene");
}


function applyFrameDatas(oNodeRoot, frameDatas, successFrameDatas, failedFrameDatas, startFrame)
{

	verbose("! Applying frameDatas");
	startFrame = startFrame || 0;

	var successFrameDatas = successFrameDatas || [];
	var failedFrameDatas = failedFrameDatas || [];
	if(Scene.getAnimRange().end / Scene.getTimeStep() < frameDatas.length)
		setTotalFrames(frameDatas.length);
	for(var i = startFrame; i < frameDatas.length; i++){
		verbose("  applying frame:", i);
		var frameData = frameDatas[i];
		if(frameData){
			var keyDatas = frameData.keyDatas;
			if(keyDatas){
				for (var j = 0; j < keyDatas.length; j++)
				{
					var keyData = keyDatas[j];
					if(applyKeyData(oNodeRoot, keyData))
						addFrameData(successFrameDatas, keyData);
					else
						addFrameData(failedFrameDatas, keyData);
				}
			}
		}
	}
}

function applyKeyData(oNodeRoot, keyData, overrideFrameIdx){
	if(!oNodeRoot || !keyData.nodeName || !keyData.propName){
		print("ERROR: cannot call applyKeyData; missing paramters. ");
		return false;
	}
	print("Creating morph frame on", keyData.nodeName, "prop:", keyData.propName, "value:", keyData.propValue);
	var oNode;
	// Try matching by name or label
	if(oNodeRoot.getName() == keyData.nodeName || oNodeRoot.getLabel() == keyData.nodeName)
		oNode = oNodeRoot;
	else
		oNode = oNodeRoot.findNodeChild(keyData.nodeName, true);
	if(!oNode)
		oNode = oNodeRoot.findNodeChildByLabel(keyData.nodeName, true);
	if(oNode){
		print("  Node found:", oNode.getName(), "/ Label:", oNode.getLabel());
		var oProp = null;

		// FIRST: Try modifier lookup (most reliable for morphs)
		oProp = getMorphPropFromNode(oNode, keyData.propName);
		if(oProp){
			print("  Found via getMorphPropFromNode");
		}

		// SECOND: Loop through all modifiers and check by label/name
		if(!oProp){
			var oObj = oNode.getObject();
			if(oObj){
				for(var m = 0; m < oObj.getNumModifiers(); m++){
					var mod = oObj.getModifier(m);
					if(mod.getLabel() === keyData.propName || mod.getName() === keyData.propName){
						// Try different methods to get the value property
						if(mod.getValueChannel){
							oProp = mod.getValueChannel();
						}
						if(!oProp && mod.getValueControl){
							oProp = mod.getValueControl();
						}
						if(!oProp && mod.getChannel){
							oProp = mod.getChannel(0);
						}
						if(oProp){
							print("  Found via modifier loop by label/name:", keyData.propName);
							break;
						}
					}
				}
			}
		}

		// LAST RESORT: Try node property lookup (for non-morph properties like poses)
		if(!oProp){
			oProp = oNode.findProperty(keyData.propName);
			if(oProp) print("  Found via findProperty (fallback)");
		}
		if(!oProp){
			oProp = oNode.findPropertyByLabel(keyData.propName);
			if(oProp) print("  Found via findPropertyByLabel (fallback)");
		}

		if(oProp){
			// DAZ Studio 6 pops a "keep limits?" dialog when a value exceeds the
			// property's min/max. Disable clamping on this property so the morph
			// applies without any prompt (guarded — the method name may differ).
			if(typeof oProp.setIsClamped === "function") oProp.setIsClamped(false);
			//var iKey = oProp.getNumKeys();
			//*********** Main action - create the morph frame;
			// if(createMorphFrameByKey(oProp, keyData.frameIdx, keyData.propValue, iKey)){
			var frameIdx = overrideFrameIdx == undefined ? keyData.frameIdx : overrideFrameIdx;
			var baseValue = (keyData.baseValue !== undefined) ? keyData.baseValue : 0;

			// Check for noSawtooth flag - just set value at this frame without affecting adjacent frames
			if (keyData.noSawtooth) {
				var timeStep = Scene.getTimeStep();
				oProp.setValue(frameIdx * timeStep, keyData.propValue);
				verbose("Set value (no sawtooth) on", keyData.nodeName, "prop:", keyData.propName, "=", keyData.propValue, "at frame", frameIdx);
				return true;
			}

			// Additive/cumulative groups: the value sustains until the group
			// end instead of sawtoothing back on the next frame. For additive
			// only the base (first) pose sustains; the rest sawtooth normally.
			if (keyData.groupMethod === "cumulative" ||
				(keyData.groupMethod === "additive" && keyData.isGroupBase)) {
				if (createSustainedMorphFrame(oProp, frameIdx, keyData.propValue, baseValue,
						keyData.groupEnd, keyData.rampContinuation === true)) {
					verbose("Successfully created sustained morph frame on", keyData.nodeName, "prop:", keyData.propName, keyData.propValue);
					return true;
				}
				logRunFailedMorph(frameIdx, keyData.nodeName, keyData.propName, "could not create sustained keyframe");
				return false;
			}

			if(createMorphFrame(oProp, frameIdx, keyData.propValue, baseValue)){
				verbose("Successfully created morph frame on", keyData.nodeName, "prop:", keyData.propName, keyData.propValue);
				return true;
			}
			else{
				logRunFailedMorph(frameIdx, keyData.nodeName, keyData.propName, "could not create keyframe");
				return false;
			}
		}
		else{
			// The frame slot itself stays (frame counts come from the declaration),
			// so ONLY this morph is missing — the rest of the ROM stays aligned.
			logRunFailedMorph(keyData.frameIdx, keyData.nodeName, keyData.propName,
				"morph/property not found on node " + oNode.getLabel());
			return false;
		}
	}
	else {
		logRunFailedMorph(keyData.frameIdx, keyData.nodeName, keyData.propName,
			"node not found under " + oNodeRoot.getLabel());
		return false
	}
}

/**********************************************************************
 * Closes the dangling sawtooth a ROM block leaves at its end: a pose preset
 * can only key frames inside its own range, so a pose on the block's LAST
 * frame has no ramp-down key after it — that morph would hold its value
 * through every block that follows (e.g. the base ROM's final FAC neck pose
 * staying on across the whole GEN range). For every keyed morph modifier on
 * `oNodes` whose last key ends before `iBoundaryFrame` at a value different
 * from its frame-0 value, key that frame-0 value at `iBoundaryFrame` — the
 * same "next frame back to base" every non-final pose gets from the sawtooth.
 * Morphs already back at their frame-0 value are untouched, so flattened
 * preserved morphs and dials set once at frame 0 stay as they are. */
/**
 * Snapshot every morph's value on the given nodes into a name→value map, taken
 * BEFORE any ROM preset is loaded (right after ApplyInitialValues). The base-ROM
 * tail close-out (closeDanglingMorphKeys) uses this to tell a CHARACTER-owned
 * shape/controller morph — one the character/GP/preset dials to a non-zero base
 * (e.g. ProportionHeight) — apart from a pure ROM pose (base ~0, e.g. the final
 * FAC "neck under chin" pose). The former must never be re-keyed at the block
 * boundary: doing so re-applied its value on top of the ERC-driven contribution,
 * so a -10% character height read as -20% by frame 327. The latter still gets
 * its dangling tail closed.
 */
function memorizeBaseMorphs(oNodes){
	var map = {};
	for(var x = 0; x < oNodes.length; x++){
		var oNode = oNodes[x];
		if(!oNode) continue;
		var oObj = oNode.getObject();
		if(!oObj) continue;
		for(var i = 0; i < oObj.getNumModifiers(); i++){
			var oMod = oObj.getModifier(i);
			if(!oMod || !oMod.inherits("DzMorph")) continue;
			var oProp = oMod.getValueControl();
			if(!oProp) continue;
			map[oMod.getName()] = oProp.getValue(0);
		}
	}
	return map;
}

// `baselineValues` (optional): the pre-ROM morph snapshot from memorizeBaseMorphs.
// When passed (the base-ROM root close-out), a morph the character dialed to a
// non-zero base is left untouched — only ROM poses (base ~0) get their tail
// closed. Without it (the DK/GP geograft + mouth close-outs, whose morphs are
// self-contained ROM assets with no character-driven base) the old getValue(0)
// behaviour is unchanged.
function closeDanglingMorphKeys(oNodes, iBoundaryFrame, baselineValues){
	var timeStep = Scene.getTimeStep();
	var tBoundary = iBoundaryFrame * timeStep;
	var iClosed = 0;
	for(var x = 0; x < oNodes.length; x++){
		var oNode = oNodes[x];
		if(!oNode) continue;
		var oObj = oNode.getObject();
		if(!oObj) continue;
		for(var i = 0; i < oObj.getNumModifiers(); i++){
			var oMod = oObj.getModifier(i);
			if(!oMod || !oMod.inherits("DzMorph")) continue;
			var oProp = oMod.getValueControl();
			if(!oProp || oProp.getNumKeys() < 1) continue;
			var iLastKey = oProp.getNumKeys() - 1;
			// A key at/past the boundary means the block manages its own tail.
			if(oProp.getKeyTime(iLastKey) >= tBoundary) continue;
			// Close BACK to the pre-ROM baseline when we have one — never to a
			// post-ROM getValue(0), which for a preset-driven controller already
			// carries the ROM's contribution and so double-applies it.
			var sKey = oMod.getName();
			var bHasBaseline = baselineValues && (baselineValues[sKey] !== undefined);
			var fBaseValue = bHasBaseline ? baselineValues[sKey] : oProp.getValue(0);
			// A morph the character dialed to a non-zero base is its OWN shape — the
			// base ROM only borrowed it. Re-keying it here is exactly what doubled
			// the value; leave character-owned morphs alone, close only ROM poses.
			if(bHasBaseline && !approx_eq(fBaseValue, 0)) continue;
			if(approx_eq(oProp.getKeyValue(iLastKey), fBaseValue)) continue;
			oProp.setValue(tBoundary, fBaseValue);
			verbose("Closed dangling key:", oProp.getLabel(), "back to", fBaseValue, "at frame", iBoundaryFrame);
			iClosed++;
		}
	}
	print("Closed", iClosed, "dangling morph key(s) at frame", iBoundaryFrame);
}

/** **************************************************************************/
function createMorphFrameByKey( oProperty, iFrame, fValue, iKey){
	if(iKey < 1){
		//verbose("")
		return false;
	}
	if( !oProperty ){
		print("Error: Property is null.");
		return false;	
	}
	if( !oProperty.inherits("DzFloatProperty")){
		print("Error: Property is not a DzFloatProperty.");		
		return false;	
	}
		verbose("Property: " + oProperty.getLabel() );
	var timeStep = Scene.getTimeStep();
	var tTarget = iFrame * timeStep;
	var tPrev = iFrame * timeStep - timeStep;
	var tNext = iFrame * timeStep + timeStep;
	var fPrevValue = oProperty.getKeyValue(iKey-1);
	var fNextValue = oProperty.getKeyValue(iKey-1);
		
	//Set the target frame to new value		
	// if (tPrev > 0){
		oProperty.setValue(tPrev, fPrevValue);
		verbose("Property ", oProperty.getLabel(), " set at frame ", tPrev/timeStep, "to", fPrevValue);
	// }
	// if (iFrame + 1 < Scene.getAnimRange().end){
		oProperty.setValue(tNext, fNextValue);
		verbose("Property ", oProperty.getLabel(), " set at frame ", tNext/timeStep, " to ", fNextValue);
	// }
	oProperty.setValue(tTarget, fValue);
	verbose("Set morph frame for", oProperty.getLabel(), "at frame", iFrame, "to value", fValue);
	return true;
}

/** **************************************************************************/
// Creates a sawtooth keyframe pattern: adjacent frames are set to fBaseValue,
// target frame is set to fValue. This prevents morph value leakage.
// fBaseValue defaults to 0 if not specified.
/* Creates a morph frame whose value SUSTAINS until the end of its group
** instead of sawtoothing back on the next frame — for additive base poses
** and cumulative group members (Custom ROM Guide generation methods).
**
** Keys: base at iFrame-1 (skipped for ramp continuations of the same prop,
** e.g. AnusOpen 22/35/80), value at iFrame, value held at iGroupEnd, base
** released at iGroupEnd+1.
*/
function createSustainedMorphFrame( oProperty, iFrame, fValue, fBaseValue, iGroupEnd, bRampContinuation ){
	if( !oProperty ){
		print("Error: Property is null.");
		return false;
	}
	if( !oProperty.inherits("DzFloatProperty")){
		print("Error: Property is not a DzFloatProperty.");
		return false;
	}
	fBaseValue = (fBaseValue !== undefined) ? fBaseValue : 0;

	var timeStep = Scene.getTimeStep();
	if (!bRampContinuation) {
		oProperty.setValue((iFrame - 1) * timeStep, fBaseValue);
		verbose("Property", oProperty.getLabel(), "set at frame", iFrame - 1, "to", fBaseValue);
	}
	oProperty.setValue(iFrame * timeStep, fValue);
	if (iGroupEnd > iFrame) {
		oProperty.setValue(iGroupEnd * timeStep, fValue);
	}
	oProperty.setValue((iGroupEnd + 1) * timeStep, fBaseValue);
	verbose("Set sustained morph frame for", oProperty.getLabel(), "at frame", iFrame, "to", fValue, "held until", iGroupEnd);
	return true;
}


function createMorphFrame( oProperty, iFrame, fValue, fBaseValue ){
	if( !oProperty ){
		print("Error: Property is null.");
		return false;
	}
	if( !oProperty.inherits("DzFloatProperty")){
		print("Error: Property is not a DzFloatProperty.");
		return false;
	}
	// Default base value to 0 for true sawtooth anchoring
	fBaseValue = (fBaseValue !== undefined) ? fBaseValue : 0;

	verbose("Property: " + oProperty.getLabel() );
	var timeStep = Scene.getTimeStep();
	var tTarget = iFrame * timeStep;
	var tPrev = iFrame * timeStep - timeStep;
	var tNext = iFrame * timeStep + timeStep;

	// Set adjacent frames to base value (not interpolated value) for true sawtooth
	oProperty.setValue(tPrev, fBaseValue);
	verbose("Property ", oProperty.getLabel(), " set at frame ", tPrev/timeStep, "to", fBaseValue);
	oProperty.setValue(tNext, fBaseValue);
	verbose("Property ", oProperty.getLabel(), " set at frame ", tNext/timeStep, " to ", fBaseValue);
	// Set target frame to the desired value
	oProperty.setValue(tTarget, fValue);
	verbose("Set morph frame for", oProperty.getLabel(), "at frame", iFrame, "to value", fValue);
	return true;
}


/* Sets selected property from DzParametersPane to it's max on the 
** current frame, setting keyframes on the previous and next
** frames to oProperty's current value
**
** - bAdvanceFrame: if true, advances frame after morph successfully sets
** - bWarnOnFail: if true, displays a message box
*/
function createMorphFrameFromSelectedProperty( bAdvanceFrame, bWarnOnFail){

	var oPaneMgr = MainWindow.getPaneMgr();
	var oPane = oPaneMgr.findPane( "DzParametersPane" );
	if( !oPane ){
		print("Error: DzParametersPane was not found.");
		return false;	
	}
	var oEditor = oPane.getNodeEditor();
	//NOTE: not sure if multiple selections are possible
	var aProperties = oEditor.getPropertySelections( true );
	for( var i = 0; i < aProperties.length; i += 1 ){
		var oProperty = aProperties[i];	
		if( createMorphFrame(oProperty, Scene.getTime()/Scene.getTimeStep(), 1) ) {
			print("Morph frames for", oProperty.getLabel, "successfully set.");
			if( bAdvanceFrame )
				Scene.stepTime();	
		} else {
			print("Morph frames for", oProperty.getLabel, "failed to set.");
			if( bWarnOnFail )
				MessageBox.critical("Morph frames for " + oProperty.getLabel() + " failed to set.",
									 "Failed to set frames", "&OK");
		}
	}
}

/**********************************************************************
 * Generation-aware figure lookup by ASSET identity. A node's label/name is
 * user-renamable, but the .dsf asset it was instantiated from is not — so the
 * source asset URI is the one rename-proof way to recognize "a Genesis 9
 * figure". Used to auto-select the character's figure instead of aborting on
 * a wrong/missing selection. */

/** The stock figure asset file names per generation ('' / unknown → null,
 *  which callers treat as "no generation check possible"). */
function dthGenerationAssetFiles(sGenesis){
	if (sGenesis == "G9") return ["genesis9.dsf"];
	if (sGenesis == "G8.1") return ["genesis8_1female.dsf", "genesis8_1male.dsf"];
	if (sGenesis == "G8") return ["genesis8female.dsf", "genesis8male.dsf"];
	if (sGenesis == "G3") return ["genesis3female.dsf", "genesis3male.dsf"];
	return null;
}

/** The node's source-asset file path, lowercased ('' when unreadable —
 *  guarded, so an API difference degrades instead of erroring). */
function dthNodeAssetPath(oNode){
	try {
		if (oNode && typeof oNode.getAssetUri == "function") {
			var oUri = oNode.getAssetUri();
			if (oUri && typeof oUri.getFilePath == "function") return String(oUri.getFilePath()).toLowerCase();
			if (oUri) return String(oUri).toLowerCase();
		}
		if (oNode && oNode.assetUri != undefined) return String(oNode.assetUri).toLowerCase();
	} catch (e) { /* fall through */ }
	return "";
}

/** Whether `oNode` is a root figure instantiated from the generation's stock
 *  asset. Unknown generation (legacy config) or an unreadable asset URI keeps
 *  the old tolerant behavior: any root DzNode passes. */
function dthIsGenerationFigure(oNode, sGenesis){
	if (!oNode || !oNode.inherits("DzNode")) return false;
	// The unreadable-asset tolerance below applies ONLY to actual figures — a
	// selected non-figure (a prop, Environment Options, …) is never accepted.
	if (!oNode.inherits("DzFigure") && !oNode.inherits("DzSkeleton")) return false;
	var aFiles = dthGenerationAssetFiles(sGenesis);
	if (!aFiles) return true;
	var sPath = dthNodeAssetPath(oNode);
	if (sPath == "") return true;
	for (var i = 0; i < aFiles.length; i++) {
		if (sPath.indexOf("/" + aFiles[i]) >= 0 || sPath == aFiles[i]) return true;
	}
	return false;
}

/** First ROOT figure in the scene instantiated from the generation's stock
 *  asset (multiple = a user error; the first wins). Null when none matches. */
function dthFindGenerationFigure(sGenesis){
	var aFiles = dthGenerationAssetFiles(sGenesis);
	if (!aFiles) return null;
	for (var i = 0; i < Scene.getNumNodes(); i++) {
		var oNode = Scene.getNode(i);
		if (!oNode || oNode.getNodeParent()) continue;
		if (!oNode.inherits("DzFigure") && !oNode.inherits("DzSkeleton")) continue;
		var sPath = dthNodeAssetPath(oNode);
		for (var j = 0; j < aFiles.length; j++) {
			if (sPath.indexOf("/" + aFiles[j]) >= 0 || sPath == aFiles[j]) return oNode;
		}
	}
	return null;
}

/*********************************************************************/
// DzNode : returns this nodes root node, or oNode if it is root
function getNodeRoot(oNode){
	if(oNode && oNode.inherits("DzNode")) {
		parent = oNode;
		while (parent){
			oNode = parent;
			parent = parent.getNodeParent();	
		}
	}
	return oNode;
}

function getSceneNameNoExt(){
	var regexFilename = RegExp("\\w*(?=\\.)");
	var aMatches = regexFilename.exec(Scene.getFilename());
	if (aMatches.length > 0)
		return aMatches[0];
	return undefined;
}


/*********************************************************************/
// String : A function for triggering an action
function triggerAction( sActionName , oSettings)
{
	var oActionMgr = MainWindow.getActionMgr();
	if( !oActionMgr ){
		print("Error: no oActionMgr found");
		return false;
	}
	
	var oAction = oActionMgr.findAction( sActionName );
	if( !oAction ){
		print("Error: no oAction found");
		return false;
	}
	
	if( !oAction.enabled ){
		print("Error:  oAction disabled");
		return false;
	}
	
	if( oSettings ){
		print("Trigger", sActionName, "with settings.");
		oAction.triggerWithSettings( oSettings );
		return true;
	} else {
		print("Trigger", sActionName, "without settings.");
		oAction.trigger();
		return true;
	}
};


function approx_eq(fValue1, fValue2){
	return Math.abs(fValue1 - fValue2) < EPSILON;
}

// Selects one or more nodes for action-based operations (e.g. Object Memorize/Restore)
// oNodes can be a single DzNode or an array of DzNodes
function selectNodes(oNodes) {
    Scene.selectAllNodes(false);
    if (!Array.isArray(oNodes)) {
        oNodes = [oNodes];
    }
    for (var i = 0; i < oNodes.length; i++) {
        if (oNodes[i]) {
            oNodes[i].select(true);
        }
    }
}

// Scans all 10 transform controls on a node for keyframes
// Returns sorted array of unique frame numbers (excluding frame 0)
function getTransformKeyframes(oNode) {
    var timeStep = Scene.getTimeStep();
    var frameMap = {};
    var controls = [
        oNode.getXPosControl(), oNode.getYPosControl(), oNode.getZPosControl(),
        oNode.getXRotControl(), oNode.getYRotControl(), oNode.getZRotControl(),
        oNode.getScaleControl(),
        oNode.getXScaleControl(), oNode.getYScaleControl(), oNode.getZScaleControl()
    ];

    for (var c = 0; c < controls.length; c++) {
        var ctrl = controls[c];
        if (!ctrl) continue;
        for (var k = 0; k < ctrl.getNumKeys(); k++) {
            var frame = Math.round(ctrl.getKeyTime(k) / timeStep);
            if (frame > 0) {
                frameMap[frame] = true;
            }
        }
    }

    var frames = [];
    for (var f in frameMap) {
        frames.push(parseInt(f));
    }
    frames.sort(function(a, b) { return a - b; });
    return frames;
}

// Restores morphs specified in options.preserveMorphs to their keepValue
// preserveMorphs format: [{ name: "body_ctrl_BreastsUp-Down", keepValue: 1 }, ...]
function restorePreservedMorphs(oNodeRoot, preserveMorphs) {
    if (!preserveMorphs || preserveMorphs.length === 0) {
        return;
    }

    for (var i = 0; i < preserveMorphs.length; i++) {
        var config = preserveMorphs[i];
        if (!config.name) continue;

        var oProp = oNodeRoot.findProperty(config.name);
        if (!oProp) {
            oProp = oNodeRoot.findPropertyByLabel(config.name);
        }
        if (!oProp) {
            oProp = getMorphPropFromNode(oNodeRoot, config.name);
        }

        if (oProp) {
            // Set all keyframes to keepValue (flattens the animation to constant)
            var numKeys = oProp.getNumKeys();
            if (numKeys > 0) {
                for (var k = 0; k < numKeys; k++) {
                    var keyTime = oProp.getKeyTime(k);
                    oProp.setValue(keyTime, config.keepValue);
                }
            } else {
                oProp.setValue(config.keepValue);
            }
            print("Restored preserved morph:", config.name, "to", config.keepValue);
        } else {
            print("WARNING: Could not find preserved morph:", config.name);
        }
    }
}

// Returns the rotation control for a bone node given an axis string.
// axis: "XRotate", "YRotate", or "ZRotate"
function getRotationControl(oNode, axis) {
    if (axis === "XRotate") return oNode.getXRotControl();
    if (axis === "YRotate") return oNode.getYRotControl();
    if (axis === "ZRotate") return oNode.getZRotControl();
    print("WARNING: Unknown rotation axis:", axis);
    return null;
}

// Pre-resolves morph property references for a list of morph entries.
// Handles "!" prefix for controller properties vs morph modifiers.
// Returns array of { oProp, range, morphName }.
function resolveMorphProps(oNodeRoot, morphEntries) {
    var resolved = [];
    for (var i = 0; i < morphEntries.length; i++) {
        var entry = morphEntries[i];
        var name = entry.morphName;
        var oProp = null;

        if (name.charAt(0) === "!") {
            // Controller property - strip prefix and find via findProperty/findPropertyByLabel
            var ctrlName = name.substring(1);
            oProp = oNodeRoot.findProperty(ctrlName);
            if (!oProp) {
                oProp = oNodeRoot.findPropertyByLabel(ctrlName);
            }
        } else {
            // Morph modifier - try getMorphPropFromNode first, then fallback
            oProp = getMorphPropFromNode(oNodeRoot, name);

            // Loop through all modifiers and check by label/name
            if (!oProp) {
                var oObj = oNodeRoot.getObject();
                if (oObj) {
                    for (var m = 0; m < oObj.getNumModifiers(); m++) {
                        var mod = oObj.getModifier(m);
                        if (mod.getLabel() === name || mod.getName() === name) {
                            if (mod.getValueChannel) {
                                oProp = mod.getValueChannel();
                            }
                            if (!oProp && mod.getValueControl) {
                                oProp = mod.getValueControl();
                            }
                            if (!oProp && mod.getChannel) {
                                oProp = mod.getChannel(0);
                            }
                            if (oProp) break;
                        }
                    }
                }
            }

            if (!oProp) {
                oProp = oNodeRoot.findProperty(name);
            }
            if (!oProp) {
                oProp = oNodeRoot.findPropertyByLabel(name);
            }
        }

        if (oProp) {
            resolved.push({ oProp: oProp, range: entry.range, morphName: name });
        } else {
            print("WARNING: Could not resolve morph property:", name);
        }
    }
    return resolved;
}

// Applies interpolated morph values based on bone rotation angle.
// Linear interpolation from angle range to value range, clamped.
// Returns count of morphs applied.
function applyMorphModEntries(resolvedEntries, angle, keyTime) {
    var count = 0;
    for (var i = 0; i < resolvedEntries.length; i++) {
        var entry = resolvedEntries[i];
        var aStart = entry.range.angle.start;
        var aEnd = entry.range.angle.end;
        var vStart = entry.range.value.start;
        var vEnd = entry.range.value.end;

        // Clamp angle to the range
        var clampedAngle;
        if (aStart < aEnd) {
            clampedAngle = Math.max(aStart, Math.min(aEnd, angle));
        } else {
            clampedAngle = Math.min(aStart, Math.max(aEnd, angle));
        }

        // Linear interpolation: map angle to value
        var t = (aEnd !== aStart) ? (clampedAngle - aStart) / (aEnd - aStart) : 0;
        var value = vStart + t * (vEnd - vStart);

        entry.oProp.setValue(keyTime, value);
        verbose("  JcmMorphMod:", entry.morphName, "angle:", angle, "-> value:", value);
        count++;
    }
    return count;
}

// Resets morphs that are exclusive to sourceEntries (not in otherEntries) to 0.
// This prevents morphs from one direction lingering when rotation crosses zero.
function resetExclusiveMorphs(sourceEntries, otherEntries, keyTime) {
    for (var i = 0; i < sourceEntries.length; i++) {
        var isShared = false;
        for (var j = 0; j < otherEntries.length; j++) {
            if (sourceEntries[i].morphName === otherEntries[j].morphName) {
                isShared = true;
                break;
            }
        }
        if (!isShared) {
            sourceEntries[i].oProp.setValue(keyTime, 0);
            verbose("  Reset exclusive morph:", sourceEntries[i].morphName, "to 0");
        }
    }
}

// Main function: applies JCM morph modifications based on bone rotation keyframes.
// Reads rotation keyframes from bones specified in jcmMorphMods config,
// then sets morph values proportionally using linear interpolation.
function applyJcmMorphMods(oNodeRoot, jcmMorphMods) {
    if (!jcmMorphMods || jcmMorphMods.length === 0) {
        return;
    }

    var timeStep = Scene.getTimeStep();

    for (var i = 0; i < jcmMorphMods.length; i++) {
        var config = jcmMorphMods[i];
        var oNode = oNodeRoot.findNodeChildByLabel(config.boneLabel, true);
        if (!oNode) {
            oNode = oNodeRoot.findNodeChild(config.boneLabel, true);
        }
        if (!oNode) {
            print("WARNING: Could not find bone node:", config.boneLabel);
            continue;
        }

        var rotCtrl = getRotationControl(oNode, config.axis);
        if (!rotCtrl) {
            print("WARNING: Could not get rotation control for", config.boneLabel, config.axis);
            continue;
        }

        // Pre-resolve morph properties
        var posEntries = resolveMorphProps(oNodeRoot, config.positive || []);
        var negEntries = resolveMorphProps(oNodeRoot, config.negative || []);

        var numKeys = rotCtrl.getNumKeys();
        print("Processing", numKeys, "rotation keyframes on", config.boneLabel, config.axis);

        for (var k = 0; k < numKeys; k++) {
            var keyTime = rotCtrl.getKeyTime(k);
            var angle = rotCtrl.getKeyValue(k);

            if (approx_eq(angle, 0)) {
                // Angle is ~0: reset all morphs to 0
                for (var p = 0; p < posEntries.length; p++) {
                    posEntries[p].oProp.setValue(keyTime, 0);
                }
                for (var n = 0; n < negEntries.length; n++) {
                    negEntries[n].oProp.setValue(keyTime, 0);
                }
            } else if (angle > 0) {
                applyMorphModEntries(posEntries, angle, keyTime);
                resetExclusiveMorphs(negEntries, posEntries, keyTime);
            } else {
                applyMorphModEntries(negEntries, angle, keyTime);
                resetExclusiveMorphs(posEntries, negEntries, keyTime);
            }
        }

        print("Applied JCM morph modifications for", config.boneLabel, config.axis,
              "- positive morphs:", posEntries.length, "negative morphs:", negEntries.length);
    }
}

// Memorizes transform properties for nodes listed in preserveNodeTransforms before ROM loading.
// Uses DAZ's Object Memorize action (DzMemorizeSelectedItemsAction) to store current transforms
// as defaults, with direct accessor save as fallback data.
// preserveNodeTransforms format: [{ nodeLabel: "Left Eye" }, ...]
function memorizeNodeTransforms(oNodeRoot, preserveNodeTransforms) {
    if (!preserveNodeTransforms || preserveNodeTransforms.length === 0) {
        return;
    }

    var resolvedNodes = [];
    for (var i = 0; i < preserveNodeTransforms.length; i++) {
        var config = preserveNodeTransforms[i];
        if (!config.nodeLabel) continue;

        var oNode = oNodeRoot.findNodeChildByLabel(config.nodeLabel, true);
        if (!oNode) {
            print("WARNING: Could not find node for transform memorize:", config.nodeLabel);
            continue;
        }

        config._node = oNode;
        resolvedNodes.push(oNode);

        // Save transform values via direct accessors (fallback data)
        var controls = [
            { label: "XTranslate", ctrl: oNode.getXPosControl() },
            { label: "YTranslate", ctrl: oNode.getYPosControl() },
            { label: "ZTranslate", ctrl: oNode.getZPosControl() },
            { label: "XRotate",    ctrl: oNode.getXRotControl() },
            { label: "YRotate",    ctrl: oNode.getYRotControl() },
            { label: "ZRotate",    ctrl: oNode.getZRotControl() },
            { label: "Scale",      ctrl: oNode.getScaleControl() },
            { label: "XScale",    ctrl: oNode.getXScaleControl() },
            { label: "YScale",    ctrl: oNode.getYScaleControl() },
            { label: "ZScale",    ctrl: oNode.getZScaleControl() }
        ];

        config.savedTransforms = [];
        for (var t = 0; t < controls.length; t++) {
            var ctrl = controls[t].ctrl;
            if (ctrl) {
                config.savedTransforms.push({
                    label: controls[t].label,
                    ctrl: ctrl,
                    value: ctrl.getValue()
                });
                verbose("Saved transform", config.nodeLabel, controls[t].label, "=", ctrl.getValue());
            }
        }
        print("Saved", config.savedTransforms.length, "transforms for node:", config.nodeLabel);
    }

    // Select all target nodes and memorize them via Object Memorize action
    if (resolvedNodes.length > 0) {
        Scene.setTime(0);
        selectNodes(resolvedNodes);
        config._useActions = triggerAction("DzMemorizeSelectedItemsAction");
        if (config._useActions) {
            print("Discovered Object Memorize/Restore actions - will use action-based restore");
        } else {
            print("WARNING: DzMemorizeSelectedItemsAction not available - will use fallback restore");
        }
    }
}

// Restores transform properties for nodes listed in preserveNodeTransforms after ROM loading.
// Primary path: uses DAZ Object Memorize/Restore actions (matching the manual workflow).
// Fallback path: uses direct setValue on all keyframes (if actions not available).
function restoreNodeTransforms(oNodeRoot, preserveNodeTransforms) {
    if (!preserveNodeTransforms || preserveNodeTransforms.length === 0) {
        return;
    }

    var timeStep = Scene.getTimeStep();

    // Check if action-based restore is available (set by memorizeNodeTransforms)
    var useActions = false;
    for (var i = 0; i < preserveNodeTransforms.length; i++) {
        if (preserveNodeTransforms[i]._useActions) {
            useActions = true;
            break;
        }
    }

    if (useActions) {
        // === ACTION-BASED RESTORE (primary path) ===
        print("Using action-based Object Memorize/Restore for transform restoration");

        // Step 1: Collect resolved nodes
        var resolvedNodes = [];
        for (var i = 0; i < preserveNodeTransforms.length; i++) {
            var config = preserveNodeTransforms[i];
            if (!config.nodeLabel) continue;
            var oNode = config._node || oNodeRoot.findNodeChildByLabel(config.nodeLabel, true);
            if (!oNode) continue;
            resolvedNodes.push(oNode);
        }

        // Step 2: At frame 0, restore memorized transforms (captured before ROM loading)
        Scene.setTime(0);
        selectNodes(resolvedNodes);
        triggerAction("DzRestoreSelectedItemsAction");
        print("Restored memorized transforms at frame 0");

        // Step 3: Memorize Figure (captures corrected frame 0 as figure defaults)
        Scene.selectAllNodes(false);
        oNodeRoot.select(true);
        Scene.setPrimarySelection(oNodeRoot);
        triggerAction("DzMemorizeFigureAction");
        print("Memorized figure for root node at frame 0");

        // Step 4: Scan keyframes on all target nodes' transform controls
        var allFrames = {};
        for (var i = 0; i < preserveNodeTransforms.length; i++) {
            var config = preserveNodeTransforms[i];
            var oNode = config._node || oNodeRoot.findNodeChildByLabel(config.nodeLabel, true);
            if (!oNode) continue;

            var nodeFrames = getTransformKeyframes(oNode);
            for (var f = 0; f < nodeFrames.length; f++) {
                allFrames[nodeFrames[f]] = true;
            }
        }

        var frameList = [];
        for (var f in allFrames) {
            frameList.push(parseInt(f));
        }
        frameList.sort(function(a, b) { return a - b; });

        print("Restoring transforms at", frameList.length, "frames:", frameList.join(", "));

        // Step 5: Select all target nodes, then restore at each keyframe
        selectNodes(resolvedNodes);
        for (var f = 0; f < frameList.length; f++) {
            Scene.setTime(frameList[f] * timeStep);
            triggerAction("DzRestoreSelectedItemsAction");
            verbose("Restored selected items at frame", frameList[f]);
        }

        print("Action-based transform restoration complete");

    } else {
        // === FALLBACK PATH (direct setValue) ===
        print("Using fallback direct setValue for transform restoration");

        for (var i = 0; i < preserveNodeTransforms.length; i++) {
            var config = preserveNodeTransforms[i];
            if (!config.nodeLabel || !config.savedTransforms) continue;

            for (var t = 0; t < config.savedTransforms.length; t++) {
                var entry = config.savedTransforms[t];
                var ctrl = entry.ctrl;
                if (!ctrl) continue;

                var savedValue = entry.value;
                var numKeys = ctrl.getNumKeys();
                if (numKeys > 0) {
                    for (var k = 0; k < numKeys; k++) {
                        ctrl.setValue(ctrl.getKeyTime(k), savedValue);
                    }
                } else {
                    ctrl.setValue(savedValue);
                }
                print("Restored transform", config.nodeLabel, entry.label, "=", savedValue, "(keys:", numKeys + ")");
            }

            print("Restored transforms for node:", config.nodeLabel);
        }
    }
}

// Apply the character's art-direction frames (inline `config.gpArtDirection` /
// `config.dkArtDirection` of the single-file character script) onto the GP/DK
// ROM block starting at `startFrame`.
function applyArtDirectionData(jsonData, oNodeRoot, startFrame) {
    if (!jsonData || !jsonData.frames || !Array.isArray(jsonData.frames)) {
        print("ERROR: art direction data missing 'frames' array");
        return false;
    }

    var timeStep = Scene.getTimeStep();
    var appliedCount = 0;

    for (var i = 0; i < jsonData.frames.length; i++) {
        var frameEntry = jsonData.frames[i];
        var absoluteFrame = parseInt(frameEntry.frame) + startFrame;

        if (!frameEntry.morphs || frameEntry.morphs.length === 0) {
            continue;
        }

        print("Applying GP art direction for", frameEntry.name, "at frame", absoluteFrame);

        for (var j = 0; j < frameEntry.morphs.length; j++) {
            var morph = frameEntry.morphs[j];

            // Find the node
            var oNode;
            if (oNodeRoot.getName() === morph.node || oNodeRoot.getLabel() === morph.node) {
                oNode = oNodeRoot;
            } else {
                oNode = oNodeRoot.findNodeChild(morph.node, true);
            }
            if (!oNode) {
                oNode = oNodeRoot.findNodeChildByLabel(morph.node, true);
            }

            if (!oNode) {
                logRunFailedMorph(absoluteFrame, morph.node, morph.prop, "node not found (art direction)");
                continue;
            }

            // Find the property
            var oProp = getMorphPropFromNode(oNode, morph.prop);
            if (!oProp) {
                var oObj = oNode.getObject();
                if (oObj) {
                    for (var m = 0; m < oObj.getNumModifiers(); m++) {
                        var mod = oObj.getModifier(m);
                        if (mod.getLabel() === morph.prop || mod.getName() === morph.prop) {
                            if (mod.getValueChannel) oProp = mod.getValueChannel();
                            if (!oProp && mod.getValueControl) oProp = mod.getValueControl();
                            if (oProp) break;
                        }
                    }
                }
            }

            // LAST RESORT: node property lookup. Geo-graft "preset" morphs (e.g.
            // Golden Palace GP_PR_*) are exposed on the figure as alias PROPERTIES,
            // not as modifiers on its object — so findModifier/getModifier miss
            // them. findProperty catches them, same as the FBM path (applyKeyData).
            if (!oProp) {
                oProp = oNode.findProperty(morph.prop);
                if (oProp) print("  Found via findProperty (fallback)");
            }
            if (!oProp) {
                oProp = oNode.findPropertyByLabel(morph.prop);
                if (oProp) print("  Found via findPropertyByLabel (fallback)");
            }

            if (!oProp) {
                logRunFailedMorph(absoluteFrame, morph.node, morph.prop, "morph/property not found (art direction)");
                continue;
            }

            // Apply the morph value at this frame using sawtooth pattern
            createMorphFrame(oProp, absoluteFrame, morph.value);
            print("  Set", morph.prop, "=", morph.value, "at frame", absoluteFrame, "(sawtooth)");
            appliedCount++;
        }
    }

    print("Applied", appliedCount, "GP art direction morphs");
    return true;
}