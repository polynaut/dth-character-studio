{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DTH Character Studio",
  "version": "package.json",
  "identifier": "com.polynaut.dthcharacterstudio",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:4330",
    "beforeDevCommand": "pnpm --filter @dth/web dev",
    "beforeBuildCommand": "pnpm --filter @dth/web build"
  },
  "app": {
    "windows": [
      {
        "title": "DTH Character Studio",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 640,
        "backgroundColor": "#2e2e2e",
        "theme": "Dark",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; form-action 'self'; frame-src 'none'",
      "devCsp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:4330; object-src 'none'; base-uri 'self'",
      "assetProtocol": {
        "enable": false
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["dcsp"],
        "name": "DTHCharacterStudioProject",
        "description": "DTH Character Studio Project",
        "role": "Editor"
      }
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "shell": {
      "open": "((https?://.+)|(.+\\.([Dd][Uu][Ff]|[Hh][Ii][Pp]|[Hh][Ii][Pp][Nn][Cc]|[Hh][Ii][Pp][Ll][Cc]|[Uu][Pp][Rr][Oo][Jj][Ee][Cc][Tt]|[Dd][Ss][Aa]|[Pp][Nn][Gg]|[Jj][Pp][Gg]|[Jj][Pp][Ee][Gg]|[Ww][Ee][Bb][Pp]|[Gg][Ii][Ff]|[Ss][Vv][Gg]|[Bb][Mm][Pp]|[Aa][Vv][Ii][Ff]|[Tt][Ii][Ff]|[Tt][Ii][Ff][Ff]|[Tt][Gg][Aa]|[Ee][Xx][Rr]|[Hh][Dd][Rr]|[Pp][Ss][Dd]|[Mm][Pp]4|[Ww][Ee][Bb][Mm]|[Mm][Oo][Vv]|[Aa][Vv][Ii]|[Mm][Kk][Vv]|[Mm][Pp]3|[Ww][Aa][Vv]|[Oo][Gg][Gg]|[Ff][Ll][Aa][Cc]|[Pp][Dd][Ff]|[Tt][Xx][Tt]|[Mm][Dd]|[Cc][Ss][Vv]|[Jj][Ss][Oo][Nn]|[Zz][Ii][Pp]|7[Zz]|[Ff][Bb][Xx]|[Oo][Bb][Jj]|[Bb][Ll][Ee][Nn][Dd]|[Aa][Bb][Cc]))|(.+[\\\\/]))"
    },
    "updater": {
      "endpoints": [
        "https://github.com/polynaut/dth-character-studio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFQUNCQzA1RDg4M0NDODcKUldTSHpJUFlCYnlzSG1HVHlWeFFJN0FtVGpJdWw3TnZ0UHQ4a0FySGNTdVlRQnRjUEdEcDRKekUK"
    }
  }
}
