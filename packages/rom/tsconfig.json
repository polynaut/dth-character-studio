{
  "extends": "../../tsconfig.base.json",
  "include": ["src"],
  "compilerOptions": {
    // The "no I/O" core: NO DOM lib — an accidental window/fetch/document
    // reference must fail to typecheck. ES2023 for the newer Array methods.
    "lib": ["ES2023"],
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true
  }
}
