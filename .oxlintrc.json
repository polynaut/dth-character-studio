{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "import", "oxc"],
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error"
  },
  "env": {
    "browser": true,
    "es2024": true
  },
  "rules": {
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "warn",
    "import/no-cycle": "error",
    "no-console": "off",
    "react/react-in-jsx-scope": "off",
    "react/no-array-index-key": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/no-unnecessary-boolean-literal-compare": "off",
    "typescript/consistent-return": "off",
    "no-control-regex": "off",

    "no-shadow": "error",
    "react/no-object-type-as-default-prop": "error",
    "react/jsx-no-constructed-context-values": "error",
    "typescript/no-unnecessary-type-assertion": "error",

    // perf/suspicious are error categories, but these specific rules flag
    // high-count INTENTIONAL patterns (see the note in
    // validate-pull-request.yml) — they stay advisory warnings on purpose:
    // sequential awaits are deliberate fs ordering, the react-markdown
    // component maps are nested by design, the __TAURI_*/__tauriMock globals
    // are the Tauri contract, and the map-spreads keep records immutable.
    "no-await-in-loop": "warn",
    "oxc/no-map-spread": "warn",
    "react/no-unstable-nested-components": "warn",
    "no-underscore-dangle": "warn",
    "import/no-unassigned-import": "warn"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/testutil.*"],
      "rules": {
        "typescript/no-floating-promises": "off",
        "typescript/no-misused-promises": "off",
        "no-shadow": "off"
      }
    }
  ],
  "ignorePatterns": [
    "**/routeTree.gen.ts",
    "**/*.gen.ts",
    "**/dist/**",
    "**/target/**",
    "**/node_modules/**"
  ]
}
